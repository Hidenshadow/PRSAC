{
  "description": "Primary PPO baseline on the lunar 32-map pool with normalized heuristic-relative reward.",
  "script": "train_cleanrl_ppo.py",
  "args": {
    "total-timesteps": 100000,
    "seed": 0,
    "map-size": 48,
    "scenario": "lunar_rover",
    "log-dir": "runs/ppo_nominal",
    "observation-mode": "terrain",
    "reward-mode": "relative_heuristic",
    "reward-scale": 10.0,
    "action-mode": "preference_delta",
    "action-gain": 3.0,
    "max-uncertainty-lambda": 1.2,
    "num-envs": 8,
    "num-steps": 64,
    "learning-rate": 0.0002,
    "num-minibatches": 8,
    "update-epochs": 4,
    "clip-coef": 0.2,
    "ent-coef": 0.01,
    "target-kl": 0.05,
    "anneal-lr": true,
    "bc-warmstart-steps": 0,
    "eval-freq": 1024,
    "n-eval-episodes": 100,
    "eval-seed": 424242,
    "early-stop-patience": 0,
    "min-eval-delta": 0.001,
    "map-sampling-mode": "map_seed_pool",
    "fixed-map-seed": 909,
    "map-seed-pool-size": 32
  }
}
