{
  "level": "lunar_viper",
  "scenario": "real_lunar_viper",
  "description": "Level 2 independent real lunar DEM benchmark with VIPER-style rover parameters. Defaults to the medium 60x60 Lunar NPD submap; difficulty configs override this tile.",
  "map_source": "maps/real_dem_tiles/lunar_npd_60_tile/real_map_layers.npz",
  "metadata": "maps/real_dem_tiles/lunar_npd_60_tile/tile_metadata.json",
  "tile_id": "lunar_npd_60_tile",
  "rover_config": "configs/rovers/viper.json",
  "split_mode": "start_goal",
  "num_train_tasks": 128,
  "num_validation_tasks": 64,
  "num_heldout_tasks": 128,
  "min_distance_ratio": 0.68,
  "task_sampling_mode": "risk_corridor",
  "min_corridor_risk": 0.48,
  "corridor_radius": 2,
  "candidate_pool_multiplier": 60,
  "mission_profile_scenario": "lunar_polar_shadow",
  "observation_mode": "terrain",
  "reward_mode": "relative_heuristic",
  "reward_scale": 10.0,
  "reward_cost_key": "scalar_cost",
  "action_mode": "preference_delta",
  "action_gain": 3.0,
  "max_uncertainty_lambda": 1.2,
  "num_envs": 8,
  "num_steps": 64,
  "learning_rate": 0.0002,
  "attacks": {
    "environment": {
      "enabled": true,
      "type": "env_composite",
      "name": "lunar_shadow_slope_belief_mismatch",
      "apply_during_training": true,
      "reward_uses_attacked_cost": true,
      "components": [
        {
          "enabled": true,
          "type": "env_traversability_boundary_mismatch",
          "mode": "risk_underestimate",
          "top_fraction": 0.20,
          "lower_slope_ratio": 0.34,
          "attack_strength": 3.0,
          "error_scale": 0.62,
          "background_error_scale": 0.03,
          "confidence_gamma": 0.90,
          "correlation_sigma": 2.8,
          "confidence_penalty_scale": 0.08,
          "confidence_floor": 0.12,
          "slope_underestimate_scale": 0.35,
          "min_confidence": 0.10,
          "max_confidence": 0.95,
          "affected_layers": ["energy", "hazard"],
          "confidence_to_uncertainty": false
        },
        {
          "enabled": true,
          "type": "env_spatial_belief_mismatch",
          "mode": "risk_underestimate",
          "selection_mode": "low_confidence_high_consequence",
          "top_fraction": 0.24,
          "attack_strength": 3.0,
          "error_scale": 0.60,
          "background_error_scale": 0.04,
          "confidence_gamma": 0.80,
          "correlation_sigma": 3.5,
          "min_confidence": 0.10,
          "max_confidence": 0.95,
          "affected_layers": ["energy", "hazard", "illumination"],
          "confidence_to_uncertainty": false
        },
        {
          "enabled": true,
          "type": "env_spatial_belief_mismatch",
          "mode": "risk_overestimate",
          "selection_mode": "path_corridor",
          "reference_policy": "risk_neutral_mission",
          "corridor_radius": 2,
          "attack_strength": 3.0,
          "error_scale": 0.22,
          "background_error_scale": 0.00,
          "confidence_gamma": 1.00,
          "correlation_sigma": 3.0,
          "min_confidence": 0.10,
          "max_confidence": 0.95,
          "affected_layers": ["energy", "hazard", "illumination"],
          "confidence_to_uncertainty": false
        }
      ]
    },
    "observation": {
      "enabled": true,
      "type": "obs_dropout",
      "dropout_prob": 0.25,
      "fill_value": 0.0,
      "clip_to_observation_space": true
    }
  }
}
