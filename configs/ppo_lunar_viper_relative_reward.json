{
  "description": "PPO baseline on the real lunar DEM / VIPER benchmark.",
  "script": "train_cleanrl_ppo.py",
  "args": {
    "env-kind": "real_terrain",
    "layers-path": "maps/real_dem_tiles/lunar_npd_60_tile/real_map_layers.npz",
    "train-tasks": "runs/lunar_viper_staged_recovery/splits/train_tasks.json",
    "eval-tasks": "runs/lunar_viper_staged_recovery/splits/validation_tasks.json",
    "scenario": "real_lunar_viper",
    "mission-profile-scenario": "lunar_polar_shadow",
    "total-timesteps": 50000,
    "seed": 0,
    "log-dir": "runs/lunar_viper_staged_recovery/nominal_train",
    "observation-mode": "terrain",
    "reward-mode": "relative_heuristic",
    "reward-scale": 10.0,
    "reward-cost-key": "attacked_scalar_cost",
    "action-mode": "preference_delta",
    "action-gain": 3.0,
    "max-uncertainty-lambda": 1.2,
    "num-envs": 8,
    "num-steps": 64,
    "learning-rate": 0.0002,
    "num-minibatches": 8,
    "update-epochs": 4,
    "clip-coef": 0.2,
    "ent-coef": 0.01,
    "target-kl": 0.05,
    "anneal-lr": true,
    "bc-warmstart-steps": 0,
    "eval-freq": 1024,
    "n-eval-episodes": 64,
    "eval-seed": 424242,
    "early-stop-patience": 0,
    "min-eval-delta": 0.001
  }
}
